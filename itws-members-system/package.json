{
  "name": "itws-members-system",
  "version": "1.0.0",
  "private": true,
  "description": "🏛️ نقابة تكنولوجيا المعلومات والبرمجيات - نظام إدارة العضويات الذكي",
  "author": "ITWS - Information Technology Workers Syndicate",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "security:audit": "npm audit && npm audit fix",
    "firebase:deploy": "firebase deploy --only firestore,storage",
    "firebase:emulators": "firebase emulators:start",
    "db:backup": "node scripts/database-backup.js",
    "db:seed": "node scripts/database-seed.js",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepare": "husky install",
    "pre-commit": "lint-staged"
  },
  "dependencies": {
    "next": "14.2.21",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "firebase": "10.14.1",
    "firebase-admin": "12.7.0",
    "cloudinary": "2.5.1",
    "next-cloudinary": "6.16.0",
    "tesseract.js": "5.1.3",
    "@tensorflow/tfjs": "4.21.0",
    "@tensorflow-models/face-detection": "1.0.3",
    "framer-motion": "11.15.0",
    "three": "0.171.0",
    "@react-three/fiber": "8.17.10",
    "@react-three/drei": "9.114.3",
    "tailwindcss": "3.4.17",
    "@tailwindcss/typography": "0.5.16",
    "postcss": "8.4.49",
    "autoprefixer": "10.4.20",
    "typescript": "5.7.3",
