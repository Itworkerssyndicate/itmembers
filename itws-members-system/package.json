    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@types/three": "0.171.0",
    "uuid": "10.0.0",
    "crypto-js": "4.2.0",
    "bcryptjs": "2.4.3",
    "jsonwebtoken": "9.0.2",
    "zod": "3.24.1",
    "react-hook-form": "7.54.2",
    "@hookform/resolvers": "3.9.1",
    "zustand": "5.0.3",
