    "clsx": "2.1.1",
    "tailwind-merge": "2.6.0",
    "class-variance-authority": "0.7.1",
    "date-fns": "4.1.0",
    "jspdf": "2.5.2",
    "html2canvas": "1.4.1",
    "react-to-print": "3.0.3",
    "qrcode": "1.5.4",
    "qrcode.react": "4.2.0",
    "device-fingerprint": "1.0.4",
    "canvas-confetti": "1.9.3",
    "sharp": "0.33.7",
    "dompurify": "3.2.3",
    "helmet": "8.0.0",
    "express-rate-limit": "7.4.1",
    "compression": "1.7.5",
    "morgan": "1.10.0",
    "winston": "3.17.0",
    "node-cron": "3.0.3",
    "nodemailer": "6.9.16"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/crypto-js": "4.2.2",
    "@types/jsonwebtoken": "9.0.7",
    "@types/uuid": "10.0.0",
    "@types/dompurify": "3.0.5",
    "@types/compression": "1.7.5",
    "@types/morgan": "1.9.9",
    "@types/nodemailer": "6.4.17",
    "@types/qrcode": "1.5.5",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.21",
    "@typescript-eslint/eslint-plugin": "8.19.1",
    "@typescript-eslint/parser": "8.19.1",
    "prettier": "3.4.2",
    "prettier-plugin-tailwindcss": "0.6.10",
    "husky": "9.1.7",
    "lint-staged": "15.3.0",
    "jest": "29.7.0",
    "@testing-library/react": "16.2.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/user-event": "14.5.2",
    "cypress": "13.17.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "browserslist": {
    "production": [
      "last 2 versions",
      "> 1%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
