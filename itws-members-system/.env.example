# ============================================================
# 🏛️ ITWS - نقابة تكنولوجيا المعلومات والبرمجيات
# إعدادات البيئة - مثال للمتغيرات المطلوبة
# ============================================================
# ⚠️ تعليمات هامة:
# 1. انسخ هذا الملف وأعد تسميته إلى .env.local
# 2. املأ القيم الفعلية من حساباتك الحقيقية
# 3. لا ترفع ملف .env.local أبداً إلى GitHub
# 4. هذا الملف .env.example مسموح رفعه (للتوثيق فقط)
# ============================================================

# ============================================================
# 🌐 Cloudinary - إعدادات الصور والوسائط
# ============================================================
# تم الحصول عليها من: https://console.cloudinary.com/
# اسم السحابة الخاص بك
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=itwmembers

# مفتاح API (آمن للعميل - مقيد بـ Upload Preset)
NEXT_PUBLIC_CLOUDINARY_API_KEY=987154869757191

# السر (يستخدم في الخادم فقط - لا يكشف للعميل أبداً)
CLOUDINARY_API_SECRET=oXlOMxIDhUG1RB16N3QKrl_2Uy4

# اسم Upload Preset للتحديدات المباشرة
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=itwsmembers

# مجلد الأصول الرئيسي
NEXT_PUBLIC_CLOUDINARY_ASSET_FOLDER=itwsmembers

# ============================================================
# 🔥 Firebase - إعدادات قاعدة البيانات والمصادقة
# ============================================================
# تم الحصول عليها من: Firebase Console → Project Settings

# مفتاح API العام (آمن للعميل)
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyDzL86AcVI1CXPCcR4OzBM4G0DPhyZYpSk

# نطاق المصادقة
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=itws-members-systems.firebaseapp.com

# معرف المشروع
NEXT_PUBLIC_FIREBASE_PROJECT_ID=itws-members-systems

# دلو التخزين
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=itws-members-systems.firebasestorage.app

# معرف مرسل الرسائل
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=108146786576

# معرف التطبيق
NEXT_PUBLIC_FIREBASE_APP_ID=1:108146786576:web:5159b3ed0ccf69ef73e595

# معرف القياس (Google Analytics)
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-4ZYPSTRM77

# ============================================================
# 🔐 Firebase Admin SDK - للخادم فقط
# ============================================================
# ⚠️ هذه القيم تستخدم في الخادم فقط ولا تكشف للعميل أبداً
# تم الحصول عليها من: Firebase Console → Service Accounts

# البريد الإلكتروني للخدمة
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@itws-members-systems.iam.gserviceaccount.com

# المفتاح الخاص (يحتوي على \n كفواصل أسطر)
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXXX\n-----END PRIVATE KEY-----\n"

# معرف المشروع (للاستخدام الإداري)
FIREBASE_ADMIN_PROJECT_ID=itws-members-systems

# ============================================================
# 🔒 JWT - إعدادات التوكين
# ============================================================
# مفتاح سري لتوقيع JWT (استخدم openssl rand -base64 64 لتوليده)
JWT_SECRET=your-generated-jwt-secret-here-change-in-production

# مدة صلاحية التوكين
JWT_EXPIRES_IN=7d

# مدة صلاحية توكين التحديث
JWT_REFRESH_EXPIRES_IN=30d

# ============================================================
# 🛡️ إعدادات الأمان المتقدمة
# ============================================================

# مفتاح تشفير البيانات الحساسة (AES-256-GCM)
ENCRYPTION_KEY=your-32-byte-encryption-key-here-change-in-production

# مفتاح توقيع الكوكيز
COOKIE_SECRET=your-cookie-secret-here-change-in-production

# تفعيل CSP (Content Security Policy)
ENABLE_CSP=true

# تفعيل HSTS
ENABLE_HSTS=true

# تفعيل CORS المقيد
ENABLE_CORS=true

# قائمة النطاقات المسموحة (مفصولة بفواصل)
ALLOWED_ORIGINS=https://itws-syndicate.vercel.app,https://itws-members-systems.web.app,https://itws-members-systems.firebaseapp.com

# ============================================================
# 📱 WhatsApp Business API
# ============================================================
# معرف حساب واتساب بيزنس
WHATSAPP_BUSINESS_ACCOUNT_ID=your-whatsapp-business-account-id

# رقم هاتف واتساب المرسل
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id

# توكين الوصول الدائم
WHATSAPP_ACCESS_TOKEN=your-whatsapp-permanent-access-token

# رمز التحقق Webhook
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# ============================================================
# 📧 إعدادات البريد الإلكتروني (اختياري)
# ============================================================
# SMTP Host
SMTP_HOST=smtp.gmail.com

# SMTP Port
SMTP_PORT=587

# SMTP User
SMTP_USER=noreply@itws-syndicate.org

# SMTP Password
SMTP_PASSWORD=your-smtp-password

# البريد الإلكتروني المرسل
MAIL_FROM=noreply@itws-syndicate.org

# اسم المرسل
MAIL_FROM_NAME=نقابة تكنولوجيا المعلومات والبرمجيات

# ============================================================
# 🤖 إعدادات OCR - التعرف على البطاقة
# ============================================================
# تفعيل OCR
ENABLE_OCR=true

# استخدام Google Cloud Vision (للخادم)
GOOGLE_CLOUD_VISION_API_KEY=your-google-cloud-vision-api-key

# استخدام Tesseract.js (للعميل)
ENABLE_TESSERACT_CLIENT=true

# ============================================================
# 📊 إعدادات التحليلات (اختياري)
# ============================================================
# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-4ZYPSTRM77

# تفعيل تتبع الأخطاء
ENABLE_ERROR_TRACKING=true

# ============================================================
# 🚀 إعدادات النشر
# ============================================================
# بيئة التشغيل
NODE_ENV=production

# عنوان URL الأساسي للتطبيق
NEXT_PUBLIC_APP_URL=https://itws-syndicate.vercel.app

# عنوان URL للـ API
NEXT_PUBLIC_API_URL=https://itws-syndicate.vercel.app/api

# إصدار التطبيق
NEXT_PUBLIC_APP_VERSION=1.0.0

# ============================================================
# 🏛️ إعدادات النقابة
# ============================================================
# اسم النقابة الكامل
NEXT_PUBLIC_SYNDICATE_NAME=نقابة تكنولوجيا المعلومات والبرمجيات

# الاسم المختصر
NEXT_PUBLIC_SYNDICATE_SHORT_NAME=ITWS

# شعار النقابة (يجب رفعه أولاً على Cloudinary)
NEXT_PUBLIC_SYNDICATE_LOGO_URL=https://res.cloudinary.com/itwmembers/image/upload/v1/itwsmembers/syndicate/logo

# ============================================================
# 🔑 مفاتيح API خارجية (اختياري)
# ============================================================
# خدمة التحقق من الرقم القومي المصري (إن وجدت)
EGYPT_NATIONAL_ID_VERIFICATION_API_KEY=your-api-key-if-available

# خدمة التحقق من الشهادات الجامعية (إن وجدت)
UNIVERSITY_DEGREE_VERIFICATION_API_KEY=your-api-key-if-available

# ============================================================
# ⚠️ ملاحظات أمنية:
# ============================================================
# 1. لا تشارك هذا الملف مع أي شخص
# 2. غير جميع كلمات المرور والمفاتيح الافتراضية
# 3. استخدم كلمات مرور قوية وعشوائية
# 4. خزن المفاتيح السرية في مدير أسرار (Secret Manager)
# 5. لا ترفع ملف .env.local إلى GitHub أبداً
# 6. قم بتدوير المفاتيح بشكل دوري (كل 90 يوم)
# 7. استخدم مفاتيح مختلفة لكل بيئة (تطوير/إنتاج)
# ============================================================
